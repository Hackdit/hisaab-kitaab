# Hisab-Kitaab Environment Variables
# Copy this to .env and fill in your values

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Upstash (Redis)
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# WhatsApp - AiSensy Business API (Production)
AISENSY_API_TOKEN=your-aisensy-api-token
AISENSY_PHONE_NUMBER=918057740281
AISENSY_API_BASE=https://api.aisensy.com

# AI/NLP
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Payments - Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# App Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Monitoring
SENTRY_DSN=your-sentry-dsn
POSTHOG_PROJECT_API_KEY=your-posthog-key

# GSTN API (Production)
GSTN_USERNAME=your-gstn-username
GSTN_PASSWORD=your-gstn-password
GSTN_CLIENT_ID=your-client-id
GSTN_CLIENT_SECRET=your-client-secret
