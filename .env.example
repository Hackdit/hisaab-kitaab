# Hisab-Kitaab Environment Variables

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash (Redis)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# WhatsApp - Twilio (Development)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp - Meta Business API (Production)
META_WEBHOOK_VERIFY_TOKEN=your-verify-token
META_ACCESS_TOKEN=your-access-token
META_PHONE_NUMBER_ID=your-phone-number-id

# AI/NLP
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key

# Payments - Razorpay
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# App Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Monitoring
SENTRY_DSN=https://your-sentry-dsn
POSTHOG_PROJECT_API_KEY=your-posthog-key

# GSTN API (Production)
GSTN_USERNAME=your-gstn-username
GSTN_PASSWORD=your-gstn-password
GSTN_CLIENT_ID=your-client-id
GSTN_CLIENT_SECRET=your-client-secret